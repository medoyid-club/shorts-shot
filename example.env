# Telegram API Configuration
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Bot Configuration
# Create bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram Channel ID
# For private channels: get ID using @userinfobot or similar
# Format: -1008888888888 (with -100 prefix)
TELEGRAM_CHANNEL=-1008888888888

# Google Gemini API Keys
# Get from https://aistudio.google.com/app/apikey
# Primary API key (50 requests/day free tier)
GEMINI_API_KEY=your_gemini_api_key_here
# Backup API key (optional, for fallback when primary quota exceeded)
GEMINI_API_KEY_BACKUP=your_backup_gemini_api_key_here
# Third backup API key (optional, for additional fallback)
GEMINI_API_KEY_OTHER_BACKUP=your_third_gemini_api_key_here
# Fourth API key with billing enabled (optional, used as last resort)
GEMINI_API_KEY_BILLING=your_billing_enabled_gemini_api_key_here

# YouTube Data API v3
# Create OAuth 2.0 credentials in Google Cloud Console
# Download JSON file and place in project root
YOUTUBE_CLIENT_SECRET_FILE=client_secret_xxxxx.apps.googleusercontent.com.json

# --- Production (Ubuntu, YouTube Shorts) ---
# Do NOT set LOCAL_ONLY. Set GEMINI_API_KEY, YOUTUBE_CLIENT_SECRET_FILE, TELEGRAM_* below.
# Optional: path to shorts_news repo for enhanced Telegram publisher (scripts + config/config.yaml)
# TELEGRAM_SHORTS_NEWS_PATH=/opt/shorts_news

# --- Sandbox (local MP4 only, no OAuth) ---
# LOCAL_ONLY=1
# LLM in sandbox: set LLM_PROVIDER=gemini or ollama; or tune [LLM] sandbox_use_ollama in config.ini
# LLM_PROVIDER=gemini
# SANDBOX_OLLAMA_MODEL=llama3.2:3b
# OLLAMA_MODEL=...
# OLLAMA_URL=http://localhost:11434
# Редко нужно: жёсткий JSON mode в Ollama (у части моделей даёт HTTP 500)
# OLLAMA_USE_JSON_FORMAT=1
# Optional: override HTML template for V2 in sandbox (default: v2_sandbox_template_path in config.ini)
# V2_SANDBOX_TEMPLATE_PATH=resources/templates/news_short_v3_glass_sandbox.html
# Fix sandbox color theme 1..5 for debugging (overrides [VIDEO] v2_sandbox_theme_debug); omit = random each run
# V2_SANDBOX_THEME_DEBUG=3